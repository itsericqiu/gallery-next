---
import CollectionCard from '@/components/CollectionCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { collectionsByType } from '@/data/collections';

const series = collectionsByType('series');
---

<BaseLayout title="Series" description="Photos by Eric Qiu, grouped by subject." path="/series/">
  <section class="hero">
    <p class="eyebrow">Series</p>
    <h1>Recurring subjects.</h1>
    <p class="lede">Photos grouped by what's in them instead of where they were taken.</p>
  </section>

  <div class="collection-grid collection-grid--series">
    {series.map((collection) => <CollectionCard collection={collection} />)}
  </div>
</BaseLayout>
