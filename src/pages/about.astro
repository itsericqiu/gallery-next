---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Eric Qiu's photos." path="/about/">
  <section class="prose-page">
    <p class="eyebrow">About</p>
    <h1>Where I put the photos.</h1>
    <p>
      I'm <a href="https://ericqiu.dev" rel="me">Eric Qiu</a>. I take photos when I travel and on walks — cities, weather, buildings, water. The ones I like end up here.
    </p>
    <p>
      The home page has a short pick. There's also one section grouping photos by place, another by subject, and a full archive.
    </p>
    <p>
      For software, writing, and how to reach me, <a href="https://ericqiu.dev">ericqiu.dev</a>.
    </p>
  </section>
</BaseLayout>
