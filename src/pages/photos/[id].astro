---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { photos, type Photo } from '@/data/photos';
import { photoImage, photoPlaceholder, detailSizes } from '@/lib/media';
import { relatedCollections } from '@/lib/collections';
import { photoSeoImage } from '@/lib/seo-images';
import { withBase } from '@/lib/urls';

export function getStaticPaths() {
  return photos.map((photo) => ({
    params: { id: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props as { photo: Photo };
const collections = relatedCollections(photo).filter((collection) => collection.type !== 'archive');
const title = photo.title ?? `Photo ${photo.id}`;
const description = photo.caption ?? (photo.place ? `A photograph from ${photo.place} by Eric Qiu.` : 'A photograph by Eric Qiu.');
const image = await photoImage(photo, 'detail');
const seoImage = await photoSeoImage(photo);
const placeholder = await photoPlaceholder(photo);
---

<BaseLayout
  title={title}
  description={description}
  path={`/photos/${photo.id}/`}
  image={seoImage.src}
  imageAlt={seoImage.alt}
  imageWidth={seoImage.width}
  imageHeight={seoImage.height}
  type="article"
>
  <article class="photo-page">
    <figure>
      <button class="photo-expand" type="button" aria-haspopup="dialog" aria-label={`Open larger view of ${title}`}>
        <img
          src={image.src}
          srcset={image.srcset}
          alt={photo.alt}
          width={image.width}
          height={image.height}
          sizes={detailSizes()}
          style={`--placeholder: url('${placeholder}')`}
          fetchpriority="high"
          decoding="async"
        />
      </button>
      <figcaption>
        <span>{photo.place ?? 'Photograph'}</span>
        <span>{photo.id}</span>
      </figcaption>
    </figure>

    <aside class="photo-meta" aria-label="Photo metadata">
      <a class="back-link" href={withBase('/archive/')}>All photographs</a>
      <h1>{title}</h1>
      <p>{description}</p>
      {collections.length > 0 && (
        <ul>
          {collections.map((collection) => (
            <li><a href={withBase(collection.slug)}>{collection.title}</a></li>
          ))}
        </ul>
      )}
    </aside>
  </article>

  <dialog class="photo-lightbox" aria-label={`Larger view of ${title}`}>
    <button class="photo-lightbox__close" type="button" aria-label="Close larger view">Close</button>
    <img
      src={image.src}
      srcset={image.srcset}
      alt={photo.alt}
      width={image.width}
      height={image.height}
      sizes="100vw"
      decoding="async"
    />
  </dialog>

  <script>
    const expand = document.querySelector<HTMLButtonElement>('.photo-expand');
    const dialog = document.querySelector<HTMLDialogElement>('.photo-lightbox');
    const close = document.querySelector<HTMLButtonElement>('.photo-lightbox__close');

    expand?.addEventListener('click', () => dialog?.showModal());
    close?.addEventListener('click', () => dialog?.close());
    dialog?.addEventListener('click', (event) => {
      const nonCloseSelectors = ['img', 'button', '[class*="close"]'];

      let el: Element | null = event.target as Element;
      let shouldClose = true;

      while (el && el !== dialog) {
        if (nonCloseSelectors.some((selector) => (el as Element).matches?.(selector))) {
          shouldClose = false;
          break;
        }
        el = el.parentElement;
      }

      if (shouldClose) {
        dialog.close();
      }
    });
  </script>
</BaseLayout>
