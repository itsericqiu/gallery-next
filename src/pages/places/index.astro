---
import CollectionCard from '@/components/CollectionCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { collectionsByType } from '@/data/collections';

const places = collectionsByType('place');
---

<BaseLayout title="Places" description="Photos by Eric Qiu, grouped by place." path="/places/">
  <section class="hero">
    <p class="eyebrow">Places</p>
    <h1>Photos grouped by where I took them.</h1>
    <p class="lede">Trips and walks, by country.</p>
  </section>

  <div class="collection-grid">
    {places.map((collection) => <CollectionCard collection={collection} />)}
  </div>
</BaseLayout>
