---
import CollectionCard from '@/components/CollectionCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { collectionsByType } from '@/data/collections';

const places = collectionsByType('place');
---

<BaseLayout title="Places" description="Place-based photo collections by Eric Qiu." path="/places/">
  <section class="hero">
    <p class="eyebrow">Places</p>
    <h1>Photographs grouped by place.</h1>
    <p class="lede">Location-based collections from trips, walks, and older folders as they make their way into the archive.</p>
  </section>

  <div class="collection-grid">
    {places.map((collection) => <CollectionCard collection={collection} />)}
  </div>
</BaseLayout>
