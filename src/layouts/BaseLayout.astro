---
import Seo from '@/components/Seo.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import { withBase } from '@/lib/urls';
import '@/styles/global.css';

type Props = {
  title: string;
  description: string;
  path?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  type?: 'website' | 'article';
};

const { title, description, path, image, imageAlt, imageWidth, imageHeight, type } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3f0ea" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
    <link rel="icon" href={withBase('/favicon-32x32.png')} type="image/png" sizes="32x32" />
    <link rel="icon" href={withBase('/favicon-16x16.png')} type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} sizes="180x180" />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <Seo
      title={title}
      description={description}
      path={path}
      image={image}
      imageAlt={imageAlt}
      imageWidth={imageWidth}
      imageHeight={imageHeight}
      type={type}
    />
    <script is:inline>
      (function() {
        var META = document.querySelector('meta[name="theme-color"]');
        var subscribers = [];

        function getEffective() {
          var explicit = document.documentElement.getAttribute('data-theme');
          if (explicit === 'dark' || explicit === 'light') return explicit;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        function apply(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          if (META) META.content = theme === 'dark' ? '#121110' : '#f3f0ea';
          for (var i = 0; i < subscribers.length; i++) {
            try { subscribers[i](theme); } catch (e) {}
          }
        }

        // Initial application
        var stored = null;
        try { stored = localStorage.getItem('theme'); } catch (e) {}
        var initial = (stored === 'dark' || stored === 'light')
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        apply(initial);

        // System change listener (only follows system if user hasn't set explicit)
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
          var s = null;
          try { s = localStorage.getItem('theme'); } catch (err) {}
          if (s !== 'dark' && s !== 'light') {
            apply(e.matches ? 'dark' : 'light');
          }
        });

        window.__theme = {
          get: getEffective,
          set: function(theme) {
            if (theme !== 'dark' && theme !== 'light') return;
            try { localStorage.setItem('theme', theme); } catch (e) {}
            apply(theme);
          },
          toggle: function() {
            this.set(getEffective() === 'dark' ? 'light' : 'dark');
          },
          subscribe: function(fn) {
            if (typeof fn !== 'function') return function() {};
            subscribers.push(fn);
            try { fn(getEffective()); } catch (e) {}
            return function unsubscribe() {
              var i = subscribers.indexOf(fn);
              if (i !== -1) subscribers.splice(i, 1);
            };
          }
        };
      })();
    </script>
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
