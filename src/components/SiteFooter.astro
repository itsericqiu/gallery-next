---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>Photos by <a href="https://ericqiu.dev" rel="me">Eric Qiu</a>.</p>
  <p><a href="https://ericqiu.dev">Main site</a> <span aria-hidden="true">·</span> <a href="https://www.instagram.com/itsericqiu">Instagram</a> <span aria-hidden="true">·</span> <span class="visually-hidden">Updated </span><time datetime={String(year)}>{year}</time></p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 13px;
    gap: 16px;
    justify-content: space-between;
    margin-top: clamp(64px, 10vw, 140px);
    padding-block: 28px;
  }

  .site-footer p {
    margin: 0;
  }

  .visually-hidden {
    border: 0;
    clip: rect(0 0 0 0);
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  @media (max-width: 520px) {
    .site-footer {
      display: grid;
    }
  }
</style>
