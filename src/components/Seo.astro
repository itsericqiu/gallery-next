---
import { absoluteUrl } from '@/lib/urls';

type Props = {
  title: string;
  description: string;
  path?: string;
  image?: string;
};

const {
  title,
  description,
  path = '/',
  image = '/og-image.jpg',
} = Astro.props;

const pageTitle = title.includes('Eric Qiu') ? title : `${title} | Eric Qiu Photos`;
const canonical = absoluteUrl(path);
const imageUrl = absoluteUrl(image);
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content="Eric Qiu" />
<meta name="copyright" content={`Copyright ${new Date().getFullYear()} Eric Qiu. All rights reserved.`} />
<meta name="rights" content="All photographs are copyright Eric Qiu and may not be reused without permission." />
<link rel="canonical" href={canonical} />
<meta property="og:site_name" content="Eric Qiu Photos" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:creator" content="@itsericqiu" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<script type="application/ld+json" is:inline set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Eric Qiu Photos',
  url: absoluteUrl('/'),
  creator: {
    '@type': 'Person',
    name: 'Eric Qiu',
    url: 'https://ericqiu.dev',
  },
  copyrightHolder: {
    '@type': 'Person',
    name: 'Eric Qiu',
  },
  copyrightNotice: `Copyright ${new Date().getFullYear()} Eric Qiu. All rights reserved.`,
})} />
